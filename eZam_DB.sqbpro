"16" value="90"/><column index="17" value="300"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="tenders_by_cpv_division" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="3" mode="1"/></sort><column_widths><column index="1" value="77"/><column index="2" value="300"/><column index="3" value="83"/><column index="4" value="63"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="tenders_by_day" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="102"/><column index="2" value="83"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="tenders_by_province_and_division" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="3" mode="1"/></sort><column_widths><column index="1" value="156"/><column index="2" value="77"/><column index="3" value="300"/><column index="4" value="83"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">-- -----------------------------------------------------------------------------
-- TABLE 10. tenders_by_cpv_division
-- Number of tenders grouped by CPV division (first 2 digits)
-- Percentages formatted as decimal (e.g., 0.39 instead of 39.0)
-- -----------------------------------------------------------------------------
DROP TABLE IF EXISTS tenders_by_cpv_division;

CREATE TABLE tenders_by_cpv_division AS
WITH raw_stats AS (
    SELECT 
        CAST(SUBSTR(cpvCode, 1, 2) AS INTEGER) AS div_id,
        COUNT(*) OVER() as total_all
    FROM raw_data
)
SELECT 
    r.div_id AS cpv_division,
    COALESCE(d.name, 'Nieznana dywizja') AS division_name,
    COUNT(*) AS tender_count,
    ROUND(COUNT(*) * 1.0 / MAX(r.total_all), 4) AS share_pct -- Wynik 0.3971 zamiast 39.71
FROM raw_stats r
LEFT JOIN cpv_dictionary d ON r.div_id = d.id
GROUP BY r.div_id, d.name
ORDER BY tender_count DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
